generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  PARENT
  CAREGIVER
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  entries       Entry[]
  timeCapsules  TimeCapsule[]
  voiceAnalyses VoiceAnalysis[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Family {
  id          String       @id @default(cuid())
  name        String
  memberships Membership[]
  babies      Baby[]
  invites     Invite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  familyId  String
  role      Role     @default(PARENT)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, familyId])
}

enum BabyTheme {
  STRAWBERRY
  STORYBOOK
}

model Baby {
  id          String      @id @default(cuid())
  name        String
  birthDate   DateTime
  theme       BabyTheme   @default(STRAWBERRY)
  avatarUrl   String?
  familyId    String
  family      Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  entries     Entry[]
  milestones  Milestone[]
  timeCapsules TimeCapsule[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum EntryType {
  LOG
  JOURNAL
  VOICE
  MILESTONE
}

model Entry {
  id          String     @id @default(cuid())
  type        EntryType
  title       String?
  content     String?    @db.Text
  occurredAt  DateTime   @default(now())
  metadata    Json?
  tags        String[]
  emotions    String[]
  aiMarkers   String[]
  babyId      String
  authorId    String
  baby        Baby       @relation(fields: [babyId], references: [id], onDelete: Cascade)
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media       Media[]
  shareTokens ShareToken[]
  voiceAnalysis VoiceAnalysis?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([babyId, occurredAt(sort: Desc)])
  @@index([babyId, type])
}

model Media {
  id           String   @id @default(cuid())
  entryId      String
  url          String
  publicId     String?
  type         String
  thumbnailUrl String?
  entry        Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

enum MilestoneCategory {
  MOTOR
  LANGUAGE
  COGNITIVE
  SOCIAL
  FEEDING
  SLEEP
}

model Milestone {
  id           String            @id @default(cuid())
  title        String
  description  String?
  category     MilestoneCategory
  ageBandMonths Int
  completedAt  DateTime?
  notes        String?
  babyId       String
  baby         Baby              @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([babyId, category])
}

model TimeCapsule {
  id              String   @id @default(cuid())
  title           String
  encryptedContent String  @db.Text
  unlockDate      DateTime
  isSealed        Boolean  @default(true)
  babyId          String
  authorId        String
  baby            Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([babyId, unlockDate])
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  familyId  String
  role      Role     @default(CAREGIVER)
  token     String   @unique @default(cuid())
  accepted  Boolean  @default(false)
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ShareToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model VoiceAnalysis {
  id            String   @id @default(cuid())
  entryId       String   @unique
  entry         Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  transcript    String   @db.Text
  summary       String?  @db.Text
  suggestedTags String[]
  firsts        String[]
  milestones    String[]
  approved      Boolean  @default(false)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
